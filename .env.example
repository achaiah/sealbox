# Example .env file for Sealbox

# Static authentication token for API access
AUTH_TOKEN=your_secret_token_here
# Or load the token from a mounted Docker secret file
# AUTH_TOKEN_FILE=/run/secrets/sealbox_auth_token

# SQLite database file path
STORE_PATH=./sealbox.db

# Address and port to listen on
LISTEN_ADDR=0.0.0.0:8080

# CLI Docker-secret-style inputs
# SEALBOX_TOKEN_FILE=/run/secrets/sealbox_auth_token
# SEALBOX_PUBLIC_KEY_FILE=/run/secrets/sealbox_public_key.pem
# SEALBOX_PRIVATE_KEY_FILE=/run/secrets/sealbox_private_key.pem
